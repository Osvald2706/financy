generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String
  avatar        String?
  currency      String   @default("MXN")
  locale        String   @default("es-MX")
  monthlyIncome Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  debts         Debt[]
  incomeRecords Income[]
  expenses      Expense[]
  goals         Goal[]
  categories    Category[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Debt {
  id            String   @id @default(cuid())
  userId        String
  name          String
  creditor      String
  type          String   @default("personal")
  totalAmount   Float
  interestRate  Float    @default(0)
  minimumPayment Float   @default(0)
  paidAmount    Float    @default(0)
  status        String   @default("active")
  dueDate       DateTime?
  startDate     DateTime @default(now())
  notes         String?  @db.Text
  category      String   @default("other")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments   DebtPayment[]
  reminders  Reminder[]
}

model DebtPayment {
  id        String   @id @default(cuid())
  debtId    String
  amount    Float
  date      DateTime @default(now())
  method    String   @default("transfer")
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model Income {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  description String?  @db.Text
  source      String   @default("salary")
  categoryId  String?
  date        DateTime @default(now())
  isRecurring Boolean  @default(false)
  frequency   String?
  nextDate    DateTime?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  description String?  @db.Text
  categoryId  String?
  date        DateTime @default(now())
  isRecurring Boolean  @default(false)
  frequency   String?
  nextDate    DateTime?
  isEssential Boolean  @default(true)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  name         String
  type         String   @default("savings")
  targetAmount Float
  currentAmount Float   @default(0)
  deadline     DateTime?
  status       String   @default("active")
  icon         String   @default("target")
  color        String   @default("emerald")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String   @default("expense")
  icon      String   @default("circle")
  color     String   @default("gray")
  budget    Float?
  createdAt DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes Income[]
  expenses Expense[]
}

model Reminder {
  id        String   @id @default(cuid())
  debtId    String?
  userId    String
  title     String
  message   String?  @db.Text
  date      DateTime
  type      String   @default("payment")
  isSent    Boolean  @default(false)
  createdAt DateTime @default(now())

  debt Debt? @relation(fields: [debtId], references: [id], onDelete: Cascade)
}
