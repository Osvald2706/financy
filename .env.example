# ===========================================
# FINANCY - Environment Variables
# ===========================================
# Copia este archivo como .env.local y completa los valores

# --- BASE DE DATOS ---
# LOCAL (SQLite - no requiere servidor):
DATABASE_URL="file:./dev.db"

# PRODUCCIÓN (PostgreSQL - Supabase gratis):
# Crear BD gratis en https://supabase.com
# Ir a Project Settings > Database > Connection string
# Pegar aquí la URI de PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# --- AUTENTICACIÓN ---
# Genera una clave secreta con: openssl rand -base64 32
NEXTAUTH_SECRET="financy-super-secret-key-change-in-production-2024"
NEXTAUTH_URL="http://localhost:3000"
# En producción (Vercel):
# NEXTAUTH_URL="https://tu-app.vercel.app"

# --- INTELIGENCIA ARTIFICIAL (GRATIS) ---
# 1. Regístrate en https://openrouter.ai/keys (sin tarjeta de crédito)
# 2. Crea una API key
# 3. Pégala aquí:
OPENROUTER_API_KEY=""
# El modelo usado es qwen/qwen3-30b-a3b:free — 100% gratuito, sin límite de tokens
